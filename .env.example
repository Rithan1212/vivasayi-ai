# ----------------------------------------------------------
#  VIVASAYI AI — frontend environment variables (Vite)
# ----------------------------------------------------------
# When this is set, the React app will call Gemini directly from
# the browser (useful for the standalone single-file demo build).
# In production deployments, leave it BLANK and route requests
# through the FastAPI backend at backend/app — never expose your
# API key on the client.

VITE_GEMINI_API_KEY=
